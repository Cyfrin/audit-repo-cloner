# GitHub personal access token
GITHUB_ACCESS_TOKEN=your_github_token_here

# GitHub organization where the audit repo will be created
GITHUB_ORGANIZATION=your_github_org_here

# GitLab personal access token (only needed if cloning from GitLab)
# Requires at minimum read_repository scope
# GITLAB_ACCESS_TOKEN=your_gitlab_token_here

# Additional GitLab hostnames for self-hosted instances (comma-separated)
# Hostnames containing "gitlab" are auto-detected and don't need to be listed here
# GITLAB_HOSTS=gitlab.internal.company.com,git.myorg.io